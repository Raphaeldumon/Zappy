{
    "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
    "name": "zappy",
    "version": "0.1.0",
    "description": "G-YEP-400 Zappy monorepo C++ dependencies",
    "dependencies": [
        "catch2",
        "nlohmann-json"
    ],
    "features": {
        "server": {
            "description": "Server runtime networking & logging",
            "dependencies": [
                "asio",
                "spdlog",
                "cli11"
            ]
        },
        "gui": {
            "description": "Vulkan GUI",
            "dependencies": [
                "vulkan-headers",
                "vulkan-memory-allocator",
                "vk-bootstrap",
                "glfw3",
                "glm",
                "glslang",
                "imgui"
            ]
        },
        "sim": {
            "description": "pybind11 simulator binding",
            "dependencies": [
                "pybind11"
            ]
        }
    }
}
